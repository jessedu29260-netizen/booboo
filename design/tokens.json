{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Booboo design tokens — single source (CRAFT.md rule zero). Consumers: site CSS vars, viewer constants, panel theme. Values stated in hex with OKLCH annotations; band hues sit at perceptually even lightness steps.",

  "color": {
    "bg": { "value": "#06080e", "oklch": "oklch(0.13 0.02 265)" },
    "bgLift": { "value": "#0a0d15", "oklch": "oklch(0.16 0.02 265)" },
    "card": { "value": "#0f131c", "oklch": "oklch(0.19 0.02 262)" },
    "line": { "value": "#1c2130", "oklch": "oklch(0.25 0.03 265)" },
    "lineHi": { "value": "#2b3243", "oklch": "oklch(0.32 0.03 263)" },
    "text": { "value": "#E8DCC4", "oklch": "oklch(0.89 0.04 90)" },
    "dim": { "value": "#8a8268", "oklch": "oklch(0.59 0.04 95)" },
    "faint": { "value": "#585240", "oklch": "oklch(0.42 0.03 95)" },
    "gold": { "value": "#c9a04a", "oklch": "oklch(0.72 0.11 85)" },
    "goldHi": { "value": "#E8C877", "oklch": "oklch(0.84 0.10 88)" },
    "teal": { "value": "#4ECDC4", "oklch": "oklch(0.79 0.10 190)" },
    "violet": { "value": "#a78bd0", "oklch": "oklch(0.68 0.10 300)" },
    "green": { "value": "#5fae7e", "oklch": "oklch(0.67 0.09 155)" },
    "amber": { "value": "#d6a23e", "oklch": "oklch(0.74 0.12 80)" },
    "red": { "value": "#d05a5a", "oklch": "oklch(0.62 0.14 25)" },

    "$house": "The staff board's own ground and metal — a warm wine-black with a real brass family, ported from the approved FHQ hero designs (03_Marketing/booboo-launch/fiverr_loud.html) so the product and its marketing are literally the same object. Rank on the board reads through brass FINISH (polished → satin → dulled), never through hue: a hash-per-agent rainbow is the loudest dev-tool tell there is.",
    "wine": { "value": "#0b0509", "oklch": "oklch(0.10 0.02 355)" },
    "wine2": { "value": "#140a11", "oklch": "oklch(0.14 0.02 350)" },
    "plate": { "value": "#1c1119", "oklch": "oklch(0.18 0.02 350)" },
    "plateLift": { "value": "#241624", "oklch": "oklch(0.22 0.03 330)" },
    "brass": { "value": "#d9a05b", "oklch": "oklch(0.75 0.10 65)" },
    "brassHi": { "value": "#efc389", "oklch": "oklch(0.85 0.08 70)" },
    "brassDeep": { "value": "#a9753a", "oklch": "oklch(0.60 0.09 60)" },
    "mint": { "value": "#8be9b0", "oklch": "oklch(0.86 0.12 155)" },
    "cream": { "value": "#f4eee2", "oklch": "oklch(0.95 0.02 85)" },
    "creamDim": { "value": "#b3a897", "oklch": "oklch(0.72 0.02 85)" },
    "creamFaint": { "value": "#7c7365", "oklch": "oklch(0.53 0.02 85)" }
  },

  "band": {
    "$description": "Pemberton bands top→bottom. disc = fill at 6% opacity, rim = ring + engraved label.",
    "gm": { "rim": "#c9a04a", "disc": "#3a2e22", "label": "GOLD · GENERAL MANAGER" },
    "executive": { "rim": "#9aa5a0", "disc": "#26302c", "label": "SILVER · DEPARTMENT HEADS" },
    "staff": { "rim": "#a8815a", "disc": "#2e2620", "label": "BRONZE · STAFF AGENTS" },
    "ledger": { "rim": "#6a5aa0", "disc": "#2a2342", "label": "THE LEDGER · MEMORY" }
  },

  "verb": {
    "$description": "Edge type → colour. One verb, one hue, everywhere.",
    "reports_to": "#c9a04a",
    "declares": "#E8C877",
    "amends": "#E8C877",
    "inherits": "#8a8268",
    "owns": "#4ECDC4",
    "reads": "#3a7a74",
    "escalates_to": "#d05a5a",
    "covers": "#5fae7e",
    "supplies": "#a8815a",
    "audits": "#a78bd0",
    "spine": "#29242f"
  },

  "luminance": {
    "$description": "The anti-dev-graph law: assigned relative luminance, brightest first. If a frame's brightest pixel is not rank 1-2, it fails QA.",
    "order": ["flag", "badge_contract", "pulse_flow", "landmark_node", "field_node", "structural_edge", "field_edge", "disc_etch", "disc", "atmosphere", "background"],
    "flag": 1.0, "badge_contract": 0.85, "pulse_flow": 0.7, "landmark_node": 0.55,
    "field_node": 0.38, "structural_edge": 0.26, "field_edge": 0.14,
    "disc_etch": 0.1, "disc": 0.06, "atmosphere": 0.04, "background": 0.02
  },

  "type": {
    "display": "Fraunces, ui-serif, Georgia, serif",
    "ui": "'DM Sans', ui-sans-serif, system-ui, sans-serif",
    "mono": "'JetBrains Mono', ui-monospace, SFMono-Regular, monospace",
    "scale": [11, 12.5, 14, 16, 19, 24, 32],
    "smallcapsTracking": "0.17em"
  },

  "motion": {
    "easing": {
      "swift": "cubic-bezier(0.2, 0.7, 0.25, 1)",
      "settle": "cubic-bezier(0.16, 1, 0.3, 1)"
    },
    "duration": { "micro": 120, "state": 300, "camera": 800, "entrance": 3500 }
  },

  "space": { "grid": 4, "radii": [2, 3, 6] },

  "z": { "canvas": 0, "hud": 10, "dossier": 20, "palette": 30, "toast": 40 }
}
