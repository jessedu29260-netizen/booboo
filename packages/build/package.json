{
  "name": "@booboo/build",
  "version": "0.0.0",
  "description": "Booboo build engine — config-driven adapters (postgres, json) + merge/walls → emits a Booboo graph.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": { "booboo": "./dist/cli.js" },
  "exports": { ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" } },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm --dts --clean",
    "test": "vitest run"
  },
  "dependencies": {
    "@booboo/spec": "workspace:*",
    "pg": "^8.13.0",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@types/pg": "^8.11.0",
    "tsup": "^8",
    "typescript": "^5",
    "vitest": "^2"
  }
}
