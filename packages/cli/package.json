{
  "name": "@booboo-brain/cli",
  "version": "0.2.0",
  "description": "Booboo CLI — one `booboo` command: build | serve | mcp | view | panel. Lazy-loads each subcommand so a build-only run never pulls the server or viewer.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jessedu29260-netizen/booboo.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/jessedu29260-netizen/booboo/issues"
  },
  "homepage": "https://github.com/jessedu29260-netizen/booboo#readme",
  "type": "module",
  "bin": {
    "booboo": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/cli.ts src/view.ts src/panel.ts --format esm --clean"
  },
  "dependencies": {
    "@booboo-brain/build": "workspace:*",
    "@booboo-brain/serve": "workspace:*",
    "@booboo-brain/spec": "workspace:*",
    "@booboo-brain/viewer": "workspace:*",
    "@booboo-brain/panel": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8",
    "typescript": "^5"
  },
  "keywords": [
    "booboo",
    "cli",
    "knowledge-graph",
    "mcp"
  ]
}
