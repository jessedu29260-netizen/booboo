{
  "name": "@booboo/viewer",
  "version": "0.0.0",
  "description": "Booboo 3D viewer — the scale-first R3F renderer. Instanced GPU field + tier-LOD. Renders any Booboo graph.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": { ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" } },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --external react,react-dom,three,@react-three/fiber,@react-three/drei,@booboo/spec",
    "dev": "vite"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@booboo/spec": "workspace:*",
    "three": "^0.184.0",
    "@react-three/fiber": "^9.0.0",
    "@react-three/drei": "^10.0.0"
  },
  "devDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.184.0",
    "vite": "^6.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "tsup": "^8",
    "typescript": "^5"
  }
}
