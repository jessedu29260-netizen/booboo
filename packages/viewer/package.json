{
  "name": "@booboo-brain/viewer",
  "version": "0.1.0",
  "description": "Booboo 3D viewer \u2014 the scale-first R3F renderer. Instanced GPU field + tier-LOD. Renders any Booboo graph.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jessedu29260-netizen/booboo.git",
    "directory": "packages/viewer"
  },
  "bugs": {
    "url": "https://github.com/jessedu29260-netizen/booboo/issues"
  },
  "homepage": "https://github.com/jessedu29260-netizen/booboo#readme",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "dist-app"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --external react,react-dom,three,@react-three/fiber,@react-three/drei,@booboo-brain/spec && vite build --config vite.app.config.ts",
    "dev": "vite"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@booboo-brain/spec": "workspace:*",
    "three": "^0.184.0",
    "@react-three/fiber": "^9.0.0",
    "@react-three/drei": "^10.0.0",
    "@react-three/postprocessing": "^3.0.4",
    "postprocessing": "^6.39.1"
  },
  "devDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.184.0",
    "vite": "^6.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "tsup": "^8",
    "typescript": "^5"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  }
}
